# P2P Debugger Environment Configuration

# ============================================
# OPERATION MODE
# ============================================
# Controls which services start via start.sh
# Options: full, watcher, minimal
# full    - All services (tracker, on-chain updates, dashboard)
# watcher - Tracker + dashboard, no on-chain updates
# minimal - Tracker only, no dashboard, no on-chain updates
OPERATION_MODE=full

# Bootstrap peer address(es) (REQUIRED)
# Single bootstrap: BOOTSTRAP_PEERS=/ip4/159.203.190.22/tcp/9100/p2p/12D3KooWN4ovysY4dp45NhLPQ9ywEhK3Z1GmaCVhQKrKHrtk1R2x
# Multiple bootstraps (comma-separated): BOOTSTRAP_PEERS=/ip4/addr1/tcp/port1/p2p/peer1,/ip4/addr2/tcp/port2/p2p/peer2
BOOTSTRAP_PEERS=/ip4/159.203.190.22/tcp/9100/p2p/12D3KooWN4ovysY4dp45NhLPQ9ywEhK3Z1GmaCVhQKrKHrtk1R2x

# Your VPS public IP (REQUIRED for proper NAT traversal)
PUBLIC_IP=YOUR_VPS_PUBLIC_IP_HERE

# Listen port (default: 8001)
LISTEN_PORT=8002

# Rendezvous point for peer discovery
# Must match across all validators in the same network
# Devnet: powerloom-dsv-devnet-alpha
# Mainnet: powerloom-dsv-mainnet-alpha
RENDEZVOUS_POINT=powerloom-dsv-devnet-alpha

# Gossipsub topic prefix for snapshot submissions
# Topic will be constructed as: {GOSSIPSUB_SNAPSHOT_SUBMISSION_PREFIX}/all
# Devnet: /powerloom/dsv-devnet-alpha/snapshot-submissions
# Mainnet: /powerloom/dsv-mainnet-alpha/snapshot-submissions
GOSSIPSUB_SNAPSHOT_SUBMISSION_PREFIX=/powerloom/dsv-devnet-alpha/snapshot-submissions

# Operation mode: PUBLISHER, LISTENER, or DISCOVERY
# - PUBLISHER: Publishes test messages at regular intervals
# - LISTENER: Listens for messages and shows peers
# - DISCOVERY: Shows peers on discovery topic (epoch 0)
MODE=PUBLISHER

# Topic to use (optional - auto-constructed from GOSSIPSUB_SNAPSHOT_SUBMISSION_PREFIX if not specified)
# If TOPIC is set, it will be used directly
# If not set, topic will be: {GOSSIPSUB_SNAPSHOT_SUBMISSION_PREFIX}/all
# - For PUBLISHER/LISTENER: {prefix}/all
# - For DISCOVERY: {prefix}/0
TOPIC=

# Publisher settings
PUBLISH_MSG=automated-test-message
# Seconds between publishes
PUBLISH_INTERVAL=30

# Listener settings
LIST_PEERS=true

# Logging
LOG_LEVEL=info

# ============================================
# VALIDATOR MESH MODE (for submission count updates)
# ============================================
# Enable validator mesh mode to listen to finalized batches and update submission counts
VALIDATOR_MESH_MODE=false

# Validator mesh topics (devnet defaults)
GOSSIPSUB_FINALIZED_BATCH_PREFIX=/powerloom/dsv-devnet-alpha/finalized-batches
GOSSIPSUB_VALIDATOR_PRESENCE_TOPIC=/powerloom/dsv-devnet-alpha/validator/presence

# Window timing (honor DSV aggregation windows)
# Wait for DSV internal Level 1 aggregation
# Level 1 finalization delay = P1 - (2/3 * P1) = P1 / 3
# Example: If P1 = 20s, then Level 1 delay = 20 - 13.33 = ~7s
LEVEL1_FINALIZATION_DELAY_SECONDS=7
# Collect validator batches after Level 1 delay (matches DSV AGGREGATION_WINDOW_SECONDS)
AGGREGATION_WINDOW_SECONDS=7

# Window tolerance (allow batches at window edges)
# Accept batches slightly before Level 1 delay completes (default: 500ms)
LEVEL1_DELAY_TOLERANCE_MS=500
# Accept batches slightly after window closes (default: 1000ms)
AGGREGATION_WINDOW_CLOSURE_TOLERANCE_MS=1000

# Tally dumps
# Directory for JSON tally files
TALLY_DUMP_DIR=./tallies
# Enable per-epoch dumps (default: true)
ENABLE_TALLY_DUMPS=true
# Write per-epoch JSON to disk (default: true). Dashboard can use Redis-only when false if ENABLE_TALLY_REDIS=true
ENABLE_TALLY_FILE_DUMPS=true
# Mirror tallies to Redis for dashboard API (default: true; requires REDIS_* and DATA_MARKET_ADDRESS)
ENABLE_TALLY_REDIS=true
# Retention in epochs = TALLY_RETENTION_EPOCHS_FACTOR * DATA_MARKET_EPOCHS_PER_DAY (default factor 1 = one protocol day).
TALLY_RETENTION_EPOCHS_FACTOR=1
# Optional: exact epoch cap (overrides factor × day size when set)
#TALLY_RETENTION_FILES=7200
# Keep files older than N calendar days (0 = unlimited by age; default: 7)
TALLY_RETENTION_DAYS=7
# Prune interval in hours (default: 1)
TALLY_PRUNE_INTERVAL_HOURS=1
# Dashboard API: max ?limit= for /epochs and /timeline = DASHBOARD_MAX_EPOCH_PAGE_FACTOR * DATA_MARKET_EPOCHS_PER_DAY (default 2)
DASHBOARD_MAX_EPOCH_PAGE_FACTOR=2

# Slack: epoch summary after each successful tally (incoming webhook; same style as snapshotter-lite-local-collector)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Optional alias: ACTIVITY_TRACKER_SLACK_WEBHOOK_URL
# Send every Nth epoch only (default 30; 0 = disabled). Uses epoch_id %% N == 0.
# SLACK_EPOCH_SUMMARY_EVERY_EPOCHS=30
# SLACK_USERNAME=Activity Tracker
# Default page size when ?limit= omitted: if DASHBOARD_DEFAULT_EPOCH_PAGE_FACTOR>=1 use factor*day size; else 500
#DASHBOARD_DEFAULT_EPOCH_PAGE_FACTOR=0
# Network topology graph: recent epochs = NETWORK_TOPOLOGY_EPOCH_FACTOR * DATA_MARKET_EPOCHS_PER_DAY / NETWORK_TOPOLOGY_DAY_FRACTION_DENOMINATOR (defaults 1/240 ≈ 30 epochs at 7200/day)
NETWORK_TOPOLOGY_EPOCH_FACTOR=1
NETWORK_TOPOLOGY_DAY_FRACTION_DENOMINATOR=240

# Contract updates (optional - disabled by default)
# Enable/disable contract updates (default: false)
ENABLE_CONTRACT_UPDATES=false
# Update every N epochs (default: 10)
SUBMISSION_UPDATE_EPOCH_INTERVAL=10
# Batch size for splitting slot IDs and submission counts (default: 50)
# EVM contracts have gas limits, so large arrays must be split into batches
REWARDS_UPDATE_BATCH_SIZE=50

# Delay between Step 1 (updateEligibleNodes) and Step 2 (updateEligibleSubmissionCounts) in seconds
# This allows Step 1 transaction to be mined before Step 2 calls start, preventing gas estimation failures
# Default: 3 seconds (recommended: 3-5 seconds depending on network block time)
STEP1_TO_STEP2_DELAY_SECONDS=3

# Contract update method: "relayer" or "direct" (only if ENABLE_CONTRACT_UPDATES=true)
CONTRACT_UPDATE_METHOD=relayer

# Relayer configuration (if CONTRACT_UPDATE_METHOD=relayer)
# When using docker-compose: Use http://relayer-py:8080 (docker service name)
# When running standalone: Use http://localhost:8080
RELAYER_URL=http://relayer-py:8080
RELAYER_AUTH_TOKEN=your_relayer_auth_token_here

# ============================================
# RELAYER-PY CONFIGURATION (for docker-compose)
# ============================================
# These environment variables are passed to the relayer-py service in docker-compose.yml
# VPA signer addresses (comma-separated) - addresses authorized to submit transactions
# IMPORTANT: These addresses must be added to ProtocolState.trustedUpdaters mapping
# See TRUSTED UPDATERS CONFIGURATION section below for details
VPA_SIGNER_ADDRESSES=0xYourSignerAddress1,0xYourSignerAddress2
# VPA signer private keys (comma-separated) - corresponding private keys (hex format, no 0x prefix)
VPA_SIGNER_PRIVATE_KEYS=your_private_key_1,your_private_key_2
# Anchor chain ID (default: 11167 for Powerloom devnet)
ANCHOR_CHAIN_ID=11167
# Minimum signer balance in ETH (default: 0 to disable for devnet)
MIN_SIGNER_BALANCE_ETH=0
# Relayer-py image configuration
# RELAYER_PY_IMAGE: Full image name (defaults to ghcr.io/powerloom/relayer-py:${RELAYER_PY_IMAGE_TAG})
# RELAYER_PY_IMAGE_TAG: Image tag (defaults to "latest")
# If ./relayer-py directory exists, docker-compose builds from source and tags with image name
# If ./relayer-py doesn't exist, docker-compose pulls pre-built image from registry
RELAYER_PY_IMAGE_TAG=latest

# Docker Compose Configuration (for relayer-py service)
# Redis Configuration (relayer-py, snapshot-activity-tracker, dashboard-api)
# In Docker Compose use REDIS_HOST=redis (service name). Local: localhost
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ Configuration (for relayer-py)
# Host ports published from the rabbitmq container (AMQP + management UI).
# Use different RABBITMQ_PORT / RABBITMQ_MGMT_PORT per stack on the same VPS.
# These must live in this file (or export + COMPOSE_ENV_FILE) — docker compose only
# substitutes ${...} from project .env / --env-file / shell, not from service env_file.
RABBITMQ_BIND_ADDR=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Relayer-py service configuration
# Note: relayer-py is NOT exposed to host - only accessible internally via Docker network
# p2p-debugger connects via http://relayer-py:8080 (Docker service name)
# RELAYER_PORT is no longer used (removed port mapping)

# Direct contract configuration (if CONTRACT_UPDATE_METHOD=direct)
# Uses POWERLOOM_RPC_URL (same as event monitoring)
# Note: This is an EVM private key (secp256k1), NOT the libp2p PRIVATE_KEY (Ed25519)
EVM_PRIVATE_KEY=your_evm_private_key_hex_here

# Data market configuration (REQUIRED for validator mesh mode)
# Note: Level 2 batches don't contain dataMarket info, so we use a single configured value
DATA_MARKET_ADDRESS=0xYourDataMarketAddress
# Epochs per protocol day for this market (used with * _FACTOR envs below). Default 7200 (~12s/epoch).
DATA_MARKET_EPOCHS_PER_DAY=7200

# Event monitoring (for EpochReleased events)
# POWERLOOM_RPC_NODES is REQUIRED for day fetching from DataMarket contract (comma-separated list)
# Supports multiple RPC nodes for failover/redundancy (same as relayer-py)
POWERLOOM_RPC_NODES=https://your-powerloom-rpc-node-1,https://your-powerloom-rpc-node-2

# Protocol State contract address
# Used for event monitoring (EpochReleased events), day fetching, and contract operations
PROTOCOL_STATE_CONTRACT=0xYourProtocolStateContractAddress

# Poll interval in seconds (default: 12)
EVENT_POLL_INTERVAL=12
# Start block for event monitoring (0 = latest)
EVENT_START_BLOCK=0
# Block batch size for event queries (default: 1000)
EVENT_BLOCK_BATCH_SIZE=1000

# ============================================
# TRUSTED UPDATERS CONFIGURATION
# ============================================
# IMPORTANT: The signer addresses configured in VPA_SIGNER_ADDRESSES must be
# added to the ProtocolState contract's trustedUpdaters mapping.
# This can be done by calling ProtocolState.addTrustedUpdater(signerAddress)
# Only addresses in trustedUpdaters can call updateRewards/updateSubmissionCounts
# functions on the ProtocolState contract.
#
# To add a trusted updater:
# 1. Call ProtocolState.addTrustedUpdater(signerAddress) from contract owner
# 2. Verify: ProtocolState.trustedUpdaters(signerAddress) returns true
# 3. The relayer-py service will use these signers to submit transactions

# ============================================
# DASHBOARD API CONFIGURATION
# ============================================
# Dashboard API port (default: 8080)
DASHBOARD_PORT=8080
# Enable dashboard API (default: true)
ENABLE_DASHBOARD=true
